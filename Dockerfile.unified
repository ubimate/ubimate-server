# ---- build stage ----
FROM node:20-alpine AS build

RUN npm install -g pnpm@8.9.2
RUN apk add --no-cache curl

WORKDIR /app

# 1 — workspace manifests (layer cache)
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY packages/types/package.json packages/types/
COPY packages/utils/package.json packages/utils/
COPY packages/crypto/package.json packages/crypto/
COPY apps/api/package.json apps/api/
COPY apps/admin/package.json apps/admin/

RUN pnpm install --frozen-lockfile

# 2 — source
COPY packages/ packages/
COPY apps/api/ apps/api/
COPY apps/admin/ apps/admin/

# 3 — build shared packages
RUN pnpm --filter @ubimate/utils build

# 4 — build admin (Vite, served at /admin/)
RUN VITE_BASE_PATH=/admin/ pnpm --filter admin build

# 5 — build API (tsc)
RUN pnpm --filter api build

# 6 — prune dev dependencies
RUN pnpm prune --prod

# ---- runtime stage ----
FROM node:20-alpine

WORKDIR /app

COPY --from=build /app/node_modules          node_modules/
COPY --from=build /app/packages              packages/
COPY --from=build /app/apps/api/dist         apps/api/dist/
COPY --from=build /app/apps/api/node_modules apps/api/node_modules/
COPY --from=build /app/apps/api/package.json apps/api/package.json
COPY --from=build /app/apps/admin/dist       apps/admin/dist/

ENV NODE_ENV=production
EXPOSE 3001

CMD ["node", "apps/api/dist/index.js"]
