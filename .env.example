# ── Required ────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-use-a-long-random-string

# Public URL of this server (used in invitation/password-reset emails)
APP_URL=https://your-server.example.com

# Allowed CORS origin(s) — set to the URL of your Ubimate desktop/web client
CORS_ORIGIN=https://your-client.example.com

# ── Admin account (created automatically on first run) ───────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_EMAIL=admin@example.com

# ── Ports (optional, defaults shown) ────────────────────────────────────────
API_PORT=3001
# Hocuspocus WebSocket is always on 1234

# ── Email / SMTP (leave blank to disable email features) ────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Registration control ─────────────────────────────────────────────────────
# Set to true to require an invitation to register
REQUIRE_INVITATION=false
INVITATION_TTL_DAYS=7

# ── Upload size limits (MB) ──────────────────────────────────────────────────
MAX_IMAGE_UPLOAD_MB=10
MAX_AUDIO_UPLOAD_MB=50
MAX_VIDEO_UPLOAD_MB=200

# ── SQLite tuning ────────────────────────────────────────────────────────────
SQLITE_BUSY_TIMEOUT_MS=5000
